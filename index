<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>臺中二中 巡堂紀錄系統</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- React & ReactDOM -->
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  
  <!-- Babel (JSX 編譯器) -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  
  <!-- Firebase (Compat 版本，免安裝工具直接載入) -->
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>

  <style>
    /* 避免 emoji 在某些裝置顯示過小 */
    .emoji-icon { font-family: "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol"; }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">
  
  <div id="root"></div>

  <!-- React 應用程式代碼 -->
  <script type="text/babel">
    const { useState, useEffect, useMemo } = React;

    // ==========================================
    // 1. 雲端資料庫初始化 (Firebase)
    // ==========================================
    const firebaseConfig = {
      apiKey: "AIzaSyDP8EfWIrGPd41KjSjIjv22okTDPTTmLIw",
      authDomain: "tcssh-patrol-system.firebaseapp.com",
      projectId: "tcssh-patrol-system",
      storageBucket: "tcssh-patrol-system.firebasestorage.app",
      messagingSenderId: "757960129787",
      appId: "1:757960129787:web:8c866b297da855b31e045e",
      measurementId: "G-YNVJB0G4NN"
    };

    firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();
    const db = firebase.firestore();
    const APP_ID = 'tcssh-patrol-system';

    // 系統設定常數
    const OFFICES = ['校長室', '教務處', '學務處', '總務處', '輔導處', '圖書館'];
    const TITLES = ['校長', '主任', '主任教官', '組長', '學創人員', '幹事', '其他'];
    const PERIODS = ['第1節', '第2節', '第3節', '第4節', '第5節', '第6節', '第7節', '第8節', '午休', '其他'];
    const VIOLATIONS = [
      { code: '✓', desc: '正常上課', isNormal: true },
      { code: 'A', desc: '嬉鬧吵雜,課堂管理欠佳', isNormal: false },
      { code: 'B', desc: '睡覺人數較多(須填寫人數)', isNormal: false },
      { code: 'C', desc: '不當使用手機或3C產品', isNormal: false },
      { code: 'D', desc: '教室或走廊髒亂', isNormal: false },
      { code: 'E', desc: '室外課教室門窗未關', isNormal: false },
      { code: 'F', desc: '室外課教室電源未關', isNormal: false },
      { code: 'G', desc: '老師無故未到(須填說明)', isNormal: false },
    ];

    function App() {
      const [currentView, setCurrentView] = useState('frontend'); 
      const [records, setRecords] = useState([]); 
      const [user, setUser] = useState(null);
      const [isSyncing, setIsSyncing] = useState(true);
      const [toast, setToast] = useState(null);

      const showToast = (msg) => {
        setToast(msg);
        setTimeout(() => setToast(null), 3000);
      };

      // 身份驗證與資料庫監聽
      useEffect(() => {
        auth.signInAnonymously().catch(err => console.error("Auth error:", err));
        const unsubscribeAuth = auth.onAuthStateChanged(setUser);
        return () => unsubscribeAuth();
      }, []);

      useEffect(() => {
        if (!user) return;
        const recordsRef = db.collection('artifacts').doc(APP_ID).collection('public').doc('data').collection('patrolRecords');
        
        const unsubscribeDB = recordsRef.onSnapshot((snapshot) => {
          const data = [];
          snapshot.forEach(doc => {
            data.push({ id: doc.id, ...doc.data() });
          });
          setRecords(data);
          setIsSyncing(false);
        }, (error) => {
          console.error("Snapshot error:", error);
          setIsSyncing(false);
        });

        return () => unsubscribeDB();
      }, [user]);

      // 寫入/更新/刪除邏輯
      const addRecordsToDB = async (newRecords) => {
        if (!user) return;
        const recordsRef = db.collection('artifacts').doc(APP_ID).collection('public').doc('data').collection('patrolRecords');
        for (const r of newRecords) {
          await recordsRef.doc(r.id).set(r);
        }
      };

      const updateRecordToDB = async (recordData) => {
        if (!user) return;
        const recordsRef = db.collection('artifacts').doc(APP_ID).collection('public').doc('data').collection('patrolRecords');
        await recordsRef.doc(recordData.id).set(recordData);
      };

      const deleteRecordFromDB = async (id) => {
        if (!user) return;
        const recordsRef = db.collection('artifacts').doc(APP_ID).collection('public').doc('data').collection('patrolRecords');
        await recordsRef.doc(id).delete();
      };

      return (
        <div className="min-h-screen">
          {/* 導覽列 */}
          <nav className="bg-blue-800 text-white shadow-md sticky top-0 z-40">
            <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <div className="flex justify-between h-16">
                <div className="flex items-center space-x-3">
                  <span className="text-2xl emoji-icon">📋</span>
                  <span className="font-bold text-lg tracking-wider">臺中二中 巡堂系統</span>
                  {user && (
                    <span className="hidden md:flex items-center text-xs text-blue-200 bg-blue-900 px-2 py-1 rounded-full ml-2">
                      <span className="mr-1 emoji-icon">☁️</span>
                      {isSyncing ? '同步中...' : '已連線雲端'}
                    </span>
                  )}
                </div>
                <div className="flex items-center space-x-1 sm:space-x-4">
                  <button 
                    onClick={() => setCurrentView('frontend')}
                    className={`px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors ${currentView === 'frontend' ? 'bg-blue-900 text-white' : 'text-blue-100 hover:bg-blue-700'}`}
                  >
                    <span className="mr-1 sm:mr-2 emoji-icon">✏️</span>
                    <span className="hidden sm:inline">填表端</span>
                    <span className="sm:hidden">填表</span>
                  </button>
                  <button 
                    onClick={() => setCurrentView('backend')}
                    className={`px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors ${currentView === 'backend' ? 'bg-blue-900 text-white' : 'text-blue-100 hover:bg-blue-700'}`}
                  >
                    <span className="mr-1 sm:mr-2 emoji-icon">⚙️</span>
                    <span className="hidden sm:inline">後台端</span>
                    <span className="sm:hidden">後台</span>
                  </button>
                </div>
              </div>
            </div>
          </nav>

          {/* 提示訊息 */}
          {toast && (
            <div className="fixed top-20 left-1/2 transform -translate-x-1/2 z-50 bg-gray-800 text-white px-4 py-2 rounded-full shadow-lg flex items-center text-sm">
              <span className="mr-2 emoji-icon">✅</span> {toast}
            </div>
          )}

          {/* 主要內容區 */}
          <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
            {currentView === 'frontend' ? (
              <FrontendView addRecords={addRecordsToDB} showToast={showToast} isSyncing={isSyncing} />
            ) : (
              <BackendView records={records} deleteRecord={deleteRecordFromDB} updateRecord={updateRecordToDB} showToast={showToast} />
            )}
          </main>
        </div>
      );
    }

    // ==========================================
    // 填表端元件 (Frontend)
    // ==========================================
    function FrontendView({ addRecords, showToast, isSyncing }) {
      const todayStr = new Date().toISOString().split('T')[0];
      const [basicInfo, setBasicInfo] = useState({ office: '', title: '', name: '', date: todayStr, period: '第1節', customPeriod: '' });
      const getEmptyRow = () => ({ id: crypto.randomUUID(), classId: '', teacher: '', violationCode: '✓', remark: '', photo: null });
      const [draftRows, setDraftRows] = useState([getEmptyRow()]);
      const [isSubmitting, setIsSubmitting] = useState(false);

      const compressImage = (file, maxWidth = 800, maxHeight = 800, quality = 0.6) => {
        return new Promise((resolve) => {
          const reader = new FileReader();
          reader.readAsDataURL(file);
          reader.onload = (event) => {
            const img = new Image();
            img.src = event.target.result;
            img.onload = () => {
              let { width, height } = img;
              if (width > height && width > maxWidth) {
                height = Math.round((height * maxWidth) / width); width = maxWidth;
              } else if (height > maxHeight) {
                width = Math.round((width * maxHeight) / height); height = maxHeight;
              }
              const canvas = document.createElement('canvas');
              canvas.width = width; canvas.height = height;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, 0, 0, width, height);
              resolve(canvas.toDataURL('image/jpeg', quality));
            };
          };
        });
      };

      const handlePhotoUpload = async (e, rowId) => {
        const file = e.target.files[0];
        if (!file) return;
        const compressedBase64 = await compressImage(file);
        updateDraftRow(rowId, 'photo', compressedBase64);
      };

      const updateBasicInfo = (field, value) => setBasicInfo(prev => ({ ...prev, [field]: value }));
      const updateDraftRow = (id, field, value) => setDraftRows(prev => prev.map(row => row.id === id ? { ...row, [field]: value } : row));
      const addRow = () => setDraftRows(prev => [...prev, getEmptyRow()]);
      const removeRow = (id) => {
        if (draftRows.length === 1) setDraftRows([getEmptyRow()]);
        else setDraftRows(prev => prev.filter(row => row.id !== id));
      };

      const submitRecords = async (rowsToSubmit) => {
        if (!basicInfo.office || !basicInfo.title || !basicInfo.name || !basicInfo.date) {
          alert("請先填寫完整「基本資料」（處室、職稱、姓名、日期）"); return;
        }
        if (basicInfo.period === '其他' && !basicInfo.customPeriod) {
          alert("請輸入自訂節次時間"); return;
        }
        if (isSyncing) { alert("系統正在連接雲端，請稍候再送出"); return; }

        setIsSubmitting(true);
        const validRows = [];
        const invalidRows = [];

        rowsToSubmit.forEach(row => {
          if (!row.classId.trim()) return;
          if (['B', 'G'].includes(row.violationCode) && !row.remark.trim()) {
            alert(`班級 ${row.classId} 選擇了違規代號 ${row.violationCode}，請務必填寫備註說明！`);
            invalidRows.push(row);
          } else {
            validRows.push({ ...row, ...basicInfo, period: basicInfo.period === '其他' ? basicInfo.customPeriod : basicInfo.period, timestamp: Date.now() });
          }
        });

        if (validRows.length === 0) {
          if (invalidRows.length === 0) alert("請至少填寫一個班級編號。");
          setIsSubmitting(false); return;
        }

        try {
          await addRecords(validRows);
          showToast(`已成功送出 ${validRows.length} 筆紀錄至雲端！`);
          const remainingDrafts = draftRows.filter(draft => !validRows.some(valid => valid.id === draft.id));
          setDraftRows(remainingDrafts.length > 0 ? remainingDrafts : [getEmptyRow()]);
        } catch (err) {
          alert("送出失敗，請確認網路連線！"); console.error(err);
        } finally {
          setIsSubmitting(false);
        }
      };

      return (
        <div className="space-y-6">
          <div className="bg-white p-5 rounded-xl shadow-sm border border-gray-100">
            <h2 className="text-lg font-bold text-gray-800 mb-4 flex items-center border-b pb-2">
              <span className="bg-blue-600 text-white w-6 h-6 rounded-full inline-flex items-center justify-center text-sm mr-2">1</span>
              填寫基本資料 <span className="text-sm font-normal text-gray-500 ml-2">(每節只需填一次)</span>
            </h2>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">處室</label>
                <select className="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border" value={basicInfo.office} onChange={e => updateBasicInfo('office', e.target.value)}>
                  <option value="">請選擇</option>{OFFICES.map(o => <option key={o} value={o}>{o}</option>)}
                </select>
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">職稱</label>
                <select className="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border" value={basicInfo.title} onChange={e => updateBasicInfo('title', e.target.value)}>
                  <option value="">請選擇</option>{TITLES.map(t => <option key={t} value={t}>{t}</option>)}
                </select>
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">姓名</label>
                <input type="text" className="w-full border-gray-300 rounded-md shadow-sm p-2 border" placeholder="您的姓名" value={basicInfo.name} onChange={e => updateBasicInfo('name', e.target.value)} />
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">日期</label>
                <input type="date" className="w-full border-gray-300 rounded-md shadow-sm p-2 border" value={basicInfo.date} onChange={e => updateBasicInfo('date', e.target.value)} />
              </div>
              <div className="flex flex-col">
                <label className="block text-sm font-medium text-gray-700 mb-1">節次</label>
                <div className="flex space-x-2">
                  <select className="w-full border-gray-300 rounded-md shadow-sm p-2 border" value={basicInfo.period} onChange={e => updateBasicInfo('period', e.target.value)}>
                    {PERIODS.map(p => <option key={p} value={p}>{p}</option>)}
                  </select>
                  {basicInfo.period === '其他' && (
                    <input type="text" className="w-full border-gray-300 rounded-md shadow-sm p-2 border" placeholder="如:07:30~08:00" value={basicInfo.customPeriod} onChange={e => updateBasicInfo('customPeriod', e.target.value)} />
                  )}
                </div>
              </div>
            </div>
          </div>

          <div className="bg-white p-5 rounded-xl shadow-sm border border-gray-100">
            <div className="flex justify-between items-end border-b pb-2 mb-4">
              <h2 className="text-lg font-bold text-gray-800 flex items-center">
                <span className="bg-blue-600 text-white w-6 h-6 rounded-full inline-flex items-center justify-center text-sm mr-2">2</span>填寫班級狀況
              </h2>
              <button onClick={addRow} className="text-sm bg-blue-100 text-blue-700 hover:bg-blue-200 px-3 py-1.5 rounded-md flex items-center font-medium">
                <span className="mr-1 emoji-icon">➕</span> 新增班級列
              </button>
            </div>

            <div className="bg-yellow-50 text-yellow-800 p-3 rounded-lg text-xs sm:text-sm mb-4 border border-yellow-200">
              <div className="font-bold mb-1">💡 違規代號說明：</div>
              <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-1">
                {VIOLATIONS.map(v => (
                  <div key={v.code} className="truncate">
                    <span className={`font-bold mr-1 ${v.isNormal ? 'text-green-600' : 'text-red-600'}`}>[{v.code}]</span> {v.desc}
                  </div>
                ))}
              </div>
            </div>

            <div className="space-y-4">
              {draftRows.map(row => (
                <div key={row.id} className="relative bg-gray-50 border border-gray-200 rounded-lg p-4 pt-8 sm:pt-4">
                  <button onClick={() => removeRow(row.id)} className="absolute top-2 right-2 text-gray-400 hover:text-red-500 bg-white rounded-full p-1 shadow-sm" title="刪除此列">
                    <span className="emoji-icon">❌</span>
                  </button>
                  <div className="grid grid-cols-1 md:grid-cols-12 gap-3 items-start">
                    <div className="md:col-span-2">
                      <label className="block text-xs font-medium text-gray-500 mb-1 md:hidden">班級</label>
                      <input type="text" placeholder="班級(例:101)" className="w-full border-gray-300 rounded-md p-2 border" value={row.classId} onChange={e => updateDraftRow(row.id, 'classId', e.target.value)} />
                    </div>
                    <div className="md:col-span-2">
                      <label className="block text-xs font-medium text-gray-500 mb-1 md:hidden">老師(選填)</label>
                      <input type="text" placeholder="老師" className="w-full border-gray-300 rounded-md p-2 border" value={row.teacher} onChange={e => updateDraftRow(row.id, 'teacher', e.target.value)} />
                    </div>
                    <div className="md:col-span-3">
                      <select className={`w-full border-gray-300 rounded-md p-2 border ${row.violationCode === '✓' ? 'text-green-700 bg-green-50' : 'text-red-700 bg-red-50'}`} value={row.violationCode} onChange={e => updateDraftRow(row.id, 'violationCode', e.target.value)}>
                        {VIOLATIONS.map(v => <option key={v.code} value={v.code}>{v.code} - {v.desc}</option>)}
                      </select>
                    </div>
                    <div className="md:col-span-3">
                      <input type="text" placeholder={['B', 'G'].includes(row.violationCode) ? "必填說明" : "備註"} className="w-full border-gray-300 rounded-md p-2 border" value={row.remark} onChange={e => updateDraftRow(row.id, 'remark', e.target.value)} />
                    </div>
                    <div className="md:col-span-1 flex justify-center">
                      <label className="cursor-pointer text-gray-500 flex flex-col items-center">
                        {row.photo ? <img src={row.photo} className="w-10 h-10 object-cover rounded-md border" /> : <span className="text-2xl emoji-icon">📷</span>}
                        <span className="text-[10px] mt-1">{row.photo ? '重選' : '拍照'}</span>
                        <input type="file" accept="image/*" capture="environment" className="hidden" onChange={e => handlePhotoUpload(e, row.id)} />
                      </label>
                    </div>
                    <div className="md:col-span-1 flex items-center h-full mt-2 md:mt-0">
                      <button onClick={() => submitRecords([row])} disabled={!row.classId || isSubmitting} className="w-full bg-indigo-600 text-white p-2 rounded-md hover:bg-indigo-700 disabled:bg-gray-300 shadow-sm flex justify-center">
                        <span className="emoji-icon">📤</span> <span className="md:hidden ml-1">送出</span>
                      </button>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <div className="mt-6 pt-4 border-t flex justify-end">
              <button onClick={() => submitRecords(draftRows)} disabled={isSubmitting} className="bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 font-bold flex items-center shadow-md">
                <span className="mr-2 text-xl emoji-icon">☁️</span> {isSubmitting ? '同步中...' : `全部送出 (${draftRows.filter(r => r.classId).length}筆)`}
              </button>
            </div>
          </div>
        </div>
      );
    }

    // ==========================================
    // 後台端元件 (Backend)
    // ==========================================
    function BackendView({ records, deleteRecord, updateRecord, showToast }) {
      const [filterDate, setFilterDate] = useState(new Date().toISOString().split('T')[0]);
      const [filterOffice, setFilterOffice] = useState('');
      const [editingRecord, setEditingRecord] = useState(null);
      const [showAddModal, setShowAddModal] = useState(false);

      const filteredRecords = useMemo(() => {
        return records
          .filter(r => filterDate ? r.date === filterDate : true)
          .filter(r => filterOffice ? r.office === filterOffice : true)
          .sort((a, b) => b.timestamp - a.timestamp);
      }, [records, filterDate, filterOffice]);

      const handleExportWord = () => {
        if (filteredRecords.length === 0) { alert("無紀錄可匯出"); return; }
        const targetDate = new Date(filterDate || filteredRecords[0].date);
        const year = targetDate.getFullYear() - 1911;
        const month = targetDate.getMonth() + 1;
        const day = targetDate.getDate();
        const weekDayStr = ['日', '一', '二', '三', '四', '五', '六'][targetDate.getDay()];
        
        let tableRows = '', photoDivs = '';
        const patrolNames = [...new Set(filteredRecords.map(r => r.name))].join('、');

        filteredRecords.forEach(r => {
          tableRows += `<tr><td style="border: 1px solid black; padding: 8px; text-align: center;">${r.classId}</td><td style="border: 1px solid black; padding: 8px; text-align: center;">${r.period}</td><td style="border: 1px solid black; padding: 8px; text-align: center;">${r.teacher || ''}</td><td style="border: 1px solid black; padding: 8px; text-align: center;">${r.violationCode === '✓' ? '正常' : r.violationCode}</td><td style="border: 1px solid black; padding: 8px; text-align: left;">${r.remark || ''}</td></tr>`;
          if (r.photo) {
            photoDivs += `<div style="margin-bottom: 20px; border: 1px solid #ccc; padding: 10px;"><h4 style="margin-top: 0;">📌 ${r.period} - 班級：${r.classId}</h4><p>狀況：${r.violationCode === '✓' ? '正常' : r.violationCode}</p><p>備註：${r.remark || '無'}</p><img src="${r.photo}" style="max-width: 500px; border: 1px solid #eee;" /></div>`;
          }
        });

        const htmlContent = `<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset="UTF-8"><style>body { font-family: "標楷體", "DFKai-sb", serif; color: #000; line-height: 1.5; } table { width: 100%; border-collapse: collapse; margin-bottom: 20px; } h1 { text-align: center; font-size: 24px; letter-spacing: 2px; } .legend { font-size: 14px; border: 1px solid #000; padding: 10px; margin-bottom: 20px; }</style></head><body><h1>臺中市立臺中第二高級中學巡堂紀錄表</h1><div style="display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 16px;"><span>日期： <u> &nbsp;${year}&nbsp; </u> 年 <u> &nbsp;${month}&nbsp; </u> 月 <u> &nbsp;${day}&nbsp; </u> 日 星期 <u> &nbsp;${weekDayStr}&nbsp; </u></span><span style="float: right;">巡堂人員： <u> &nbsp;${patrolNames || '_______________'}&nbsp; </u></span></div><table style="border: 1px solid black;"><thead><tr><th style="border: 1px solid black; padding: 8px; width: 12%; background-color: #f2f2f2;">班別</th><th style="border: 1px solid black; padding: 8px; width: 12%; background-color: #f2f2f2;">節次</th><th style="border: 1px solid black; padding: 8px; width: 15%; background-color: #f2f2f2;">任課老師</th><th style="border: 1px solid black; padding: 8px; width: 15%; background-color: #f2f2f2;">紀錄</th><th style="border: 1px solid black; padding: 8px; width: 46%; background-color: #f2f2f2;">違規及待改進事項</th></tr></thead><tbody>${tableRows || '<tr><td colspan="5" style="border: 1px solid black; text-align: center; padding: 10px;">無紀錄</td></tr>'}</tbody></table><div class="legend"><strong>紀錄代號：</strong><br>A. 嬉鬧吵雜,課堂管理欠佳<br>B. 睡覺人數較多(請註記:大概人數*n)<br>C. 不當使用手機或3C產品(請學生到走廊登記學號)<br>D. 教室或走廊髒亂<br>E. 室外課教室 門窗未關閉 &nbsp;&nbsp;&nbsp;&nbsp; F. 室外課教室 電源未關閉<br>G. 老師無故未到</div><table style="width: 100%; margin-top: 40px; border: none;"><tr><td style="border: none; text-align: left; vertical-align: bottom; height: 80px;">巡堂：<br><br><br>_________________</td><td style="border: none; text-align: left; vertical-align: bottom;">會簽：<br><br><br>學務處：___________  <br>其他：_____________</td><td style="border: none; text-align: left; vertical-align: bottom;">教學組長：<br><br><br>_________________</td><td style="border: none; text-align: left; vertical-align: bottom;">教務主任：<br><br><br>_________________</td><td style="border: none; text-align: left; vertical-align: bottom;">校長：<br><br><br>_________________</td></tr></table>${photoDivs ? `<br clear=all style='mso-special-character:line-break;page-break-before:always'><h2 style="text-align: center; border-bottom: 2px solid #000; padding-bottom: 10px;">附件：巡堂照片紀錄</h2>${photoDivs}` : ''}</body></html>`;

        const blob = new Blob(['\ufeff', htmlContent], { type: 'application/msword;charset=utf-8;' });
        const link = document.createElement("a"); link.href = URL.createObjectURL(blob); link.download = `巡堂紀錄表_${filterDate}.doc`; link.click();
      };

      const handleExportCSV = () => {
        if (records.length === 0) { alert("無紀錄可匯出"); return; }
        const headers = ['日期', '節次', '處室', '職稱', '姓名', '班級', '任課老師', '代號', '備註', '時間戳記'];
        const rows = records.map(r => [r.date, r.period, r.office, r.title, r.name, r.classId, r.teacher || '', r.violationCode, r.remark || '', new Date(r.timestamp).toLocaleString()].map(f => `"${String(f).replace(/"/g, '""')}"`).join(','));
        const blob = new Blob(["\uFEFF" + headers.join(',') + '\n' + rows.join('\n')], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement("a"); link.href = URL.createObjectURL(blob); link.download = `巡堂紀錄_${filterDate}.csv`; link.click();
      };

      const stats = {
        total: records.length, violations: records.filter(r => r.violationCode !== '✓').length,
        todayTotal: records.filter(r => r.date === new Date().toISOString().split('T')[0]).length,
        todayViolations: records.filter(r => r.date === new Date().toISOString().split('T')[0] && r.violationCode !== '✓').length
      };

      return (
        <div className="space-y-6">
          <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div className="bg-white p-4 rounded-xl shadow border text-center">
              <div className="text-gray-500 text-sm mb-1">系統總班次</div><div className="text-3xl font-bold text-blue-600">{stats.total}</div>
            </div>
            <div className="bg-white p-4 rounded-xl shadow border text-center">
              <div className="text-gray-500 text-sm mb-1">系統違規班次</div><div className="text-3xl font-bold text-red-500">{stats.violations}</div>
            </div>
            <div className="bg-white p-4 rounded-xl shadow border text-center">
              <div className="text-gray-500 text-sm mb-1">今日巡堂班次</div><div className="text-3xl font-bold text-green-600">{stats.todayTotal}</div>
            </div>
            <div className="bg-white p-4 rounded-xl shadow border text-center">
              <div className="text-gray-500 text-sm mb-1">今日違規班次</div><div className="text-3xl font-bold text-orange-500">{stats.todayViolations}</div>
            </div>
          </div>

          <div className="bg-white p-4 rounded-xl shadow border flex flex-col md:flex-row justify-between items-center gap-4">
            <div className="flex items-center gap-3">
              <span className="bg-gray-100 p-2 rounded-md emoji-icon">🔍</span>
              <input type="date" className="border rounded p-2 text-sm" value={filterDate} onChange={e => setFilterDate(e.target.value)} />
              <select className="border rounded p-2 text-sm" value={filterOffice} onChange={e => setFilterOffice(e.target.value)}>
                <option value="">所有處室</option>{OFFICES.map(o => <option key={o} value={o}>{o}</option>)}
              </select>
            </div>
            <div className="flex space-x-2">
              <button onClick={() => setShowAddModal(true)} className="bg-blue-100 text-blue-700 px-4 py-2 rounded font-medium"><span className="emoji-icon">➕</span> 補充</button>
              <button onClick={handleExportWord} className="bg-blue-600 text-white px-4 py-2 rounded font-medium"><span className="emoji-icon">🖨️</span> Word檔</button>
              <button onClick={handleExportCSV} className="bg-green-600 text-white px-4 py-2 rounded font-medium"><span className="emoji-icon">📥</span> CSV</button>
            </div>
          </div>

          <div className="bg-white rounded-xl shadow border overflow-x-auto">
            <table className="min-w-full divide-y divide-gray-200">
              <thead className="bg-gray-50">
                <tr><th className="px-4 py-3 text-left text-xs text-gray-500">日期/節次</th><th className="px-4 py-3 text-left text-xs text-gray-500">巡堂人員</th><th className="px-4 py-3 text-left text-xs text-gray-500">班級/老師</th><th className="px-4 py-3 text-left text-xs text-gray-500">狀況</th><th className="px-4 py-3 text-left text-xs text-gray-500">備註/照片</th><th className="px-4 py-3 text-right text-xs text-gray-500">操作</th></tr>
              </thead>
              <tbody className="bg-white divide-y divide-gray-200">
                {filteredRecords.length === 0 ? <tr><td colSpan="6" className="text-center p-10 text-gray-500"><div className="text-4xl emoji-icon">📄</div>無紀錄</td></tr> : 
                  filteredRecords.map(r => (
                    <tr key={r.id}>
                      <td className="px-4 py-3 text-sm">{r.date}<br/><span className="text-gray-500 text-xs">{r.period}</span></td>
                      <td className="px-4 py-3 text-sm">{r.name}<br/><span className="text-gray-500 text-xs">{r.office}</span></td>
                      <td className="px-4 py-3 text-sm font-bold text-blue-700">{r.classId}<br/><span className="text-gray-500 text-xs font-normal">{r.teacher || '-'}</span></td>
                      <td className="px-4 py-3 text-sm"><span className={`px-2 py-1 rounded-full text-xs ${r.violationCode === '✓' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>{r.violationCode}</span></td>
                      <td className="px-4 py-3 text-sm">{r.remark || '-'} {r.photo && <img src={r.photo} className="h-8 w-8 mt-1 border cursor-pointer" onClick={() => window.open(r.photo)} />}</td>
                      <td className="px-4 py-3 text-right">
                        <button onClick={() => setEditingRecord(r)} className="text-indigo-600 bg-indigo-50 p-2 rounded mr-2 emoji-icon">✏️</button>
                        <button onClick={() => { if(window.confirm("刪除這筆？")) { deleteRecord(r.id); showToast("已刪除"); } }} className="text-red-600 bg-red-50 p-2 rounded emoji-icon">🗑️</button>
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          {(editingRecord || showAddModal) && (
            <EditModal record={editingRecord} isAdd={showAddModal} defaultDate={filterDate} onClose={() => { setEditingRecord(null); setShowAddModal(false); }} onSave={async (data) => {
              if (showAddModal) { await updateRecord({...data, id: crypto.randomUUID(), timestamp: Date.now()}); showToast("補充完成"); } 
              else { await updateRecord(data); showToast("更新完成"); }
              setEditingRecord(null); setShowAddModal(false);
            }} />
          )}
        </div>
      );
    }

    // ==========================================
    // 編輯與補充 Modal 共用元件
    // ==========================================
    function EditModal({ record, isAdd, defaultDate, onClose, onSave }) {
      const [formData, setFormData] = useState(record || { date: defaultDate || new Date().toISOString().split('T')[0], period: '第1節', office: '', title: '', name: '', classId: '', teacher: '', violationCode: '✓', remark: '', photo: null });
      const handleChange = (e) => setFormData(prev => ({ ...prev, [e.target.name]: e.target.value }));

      const handleSubmit = async (e) => {
        e.preventDefault();
        if (!formData.classId || !formData.date || !formData.office || !formData.name) return alert("必填欄位缺失");
        await onSave(formData);
      };

      return (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
          <div className="bg-white rounded-xl shadow-2xl w-full max-w-2xl flex flex-col max-h-[90vh]">
            <div className="p-4 border-b flex justify-between"><h3 className="font-bold">{isAdd ? '➕ 補充漏填' : '✏️ 修改紀錄'}</h3><button onClick={onClose} className="emoji-icon">❌</button></div>
            <div className="p-6 overflow-y-auto">
              <form id="edit-form" onSubmit={handleSubmit} className="space-y-4">
                <div className="grid grid-cols-2 gap-4">
                  <input type="date" name="date" required value={formData.date} onChange={handleChange} className="border p-2 rounded w-full" />
                  <input type="text" name="period" required value={formData.period} onChange={handleChange} className="border p-2 rounded w-full" />
                </div>
                <div className="grid grid-cols-3 gap-4">
                  <select name="office" required value={formData.office} onChange={handleChange} className="border p-2 rounded w-full"><option value="">處室</option>{OFFICES.map(o => <option key={o}>{o}</option>)}</select>
                  <select name="title" value={formData.title} onChange={handleChange} className="border p-2 rounded w-full"><option value="">職稱</option>{TITLES.map(t => <option key={t}>{t}</option>)}</select>
                  <input type="text" name="name" required placeholder="姓名" value={formData.name} onChange={handleChange} className="border p-2 rounded w-full" />
                </div>
                <div className="grid grid-cols-2 gap-4">
                  <input type="text" name="classId" required placeholder="班級" value={formData.classId} onChange={handleChange} className="border p-2 rounded w-full" />
                  <input type="text" name="teacher" placeholder="老師" value={formData.teacher} onChange={handleChange} className="border p-2 rounded w-full" />
                </div>
                <select name="violationCode" required value={formData.violationCode} onChange={handleChange} className="border p-2 rounded w-full">
                  {VIOLATIONS.map(v => <option key={v.code} value={v.code}>{v.code} - {v.desc}</option>)}
                </select>
                <textarea name="remark" value={formData.remark} onChange={handleChange} rows="3" placeholder="備註說明" className="border p-2 rounded w-full"></textarea>
              </form>
            </div>
            <div className="p-4 border-t flex justify-end space-x-3">
              <button onClick={onClose} className="px-4 py-2 border rounded">取消</button>
              <button type="submit" form="edit-form" className="px-4 py-2 bg-blue-600 text-white rounded">儲存</button>
            </div>
          </div>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
